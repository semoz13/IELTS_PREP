# ── AI API Keys ────────────────────────────────────────────────────────────────
# Gemini — used by Jawa reading (passage generation) and listening (question gen)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic — used by Roy writing feedback.py (Claude Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional ───────────────────────────────────────────────────────────────────
# CORS origins for the AI service (comma-separated, default: *)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Path overrides — use these if you store .pt files outside ai_service/writing/
# TASK1_MODEL_PATH=/absolute/path/to/task1_model_best.pt
# TASK2_MODEL_PATH=/absolute/path/to/task2_model_best.pt

# Path override for confidence model
# CONFIDENCE_MODEL_PATH=/absolute/path/to/exp1_model.pkl

# Whisper model size: tiny | base | small | medium (default: base for speed)
# WHISPER_MODEL_SIZE=base
